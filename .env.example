RTSP_URL_105=rtsp://user:password@192.168.0.105:554/stream1
RTSP_URL_106=rtsp://user:password@192.168.0.106:554/stream1
RTSP_URL_107=rtsp://user:password@192.168.0.107:554/stream1

# Optional. Leave blank for auto-detect.
MANNEQUIN_SERIAL_ENABLED=true
MANNEQUIN_SERIAL_PORT=
MANNEQUIN_SERIAL_BAUD=115200
MANNEQUIN_VOLUME_MIN_ML=400
MANNEQUIN_VOLUME_MAX_ML=600
MANNEQUIN_GT_READY_MAX_AGE_SEC=10

# Optional fallback: subscribe to abc_collector_v3 serial WebSocket if it is running.
ABC_SENSOR_BRIDGE_ENABLED=true
ABC_SENSOR_BRIDGE_URL=ws://127.0.0.1:8010/ws
